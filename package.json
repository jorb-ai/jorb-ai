{
  "name": "jorb-ai-desktop",
  "version": "0.1.0",
  "description": "Jorb AI desktop app — automated job applications via CDP",
  "main": "dist/main/main.js",
  "author": "Jorb AI",
  "license": "MIT",
  "scripts": {
    "build": "tsc --project tsconfig.main.json && vite build",
    "dev": "npm run build && electron .",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "@types/ws": "^8.18.1",
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3",
    "vite": "^7.2.2"
  },
  "build": {
    "appId": "ai.jorb.desktop",
    "productName": "Jorb AI",
    "files": [
      "dist/**/*",
      "build/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
